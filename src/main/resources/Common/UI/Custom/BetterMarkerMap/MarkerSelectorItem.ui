$C = "../Common.ui";

Group {
  Anchor: (Width: 172, Height: 214);
  LayoutMode: Top;
  Padding: (Left: 6, Right: 6, Top: 6, Bottom: 6);

  Group #Card {
    Anchor: (Width: 160, Height: 202);
    LayoutMode: Top;
    Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
    Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 8);

    Group #PreviewBox {
      Anchor: (Width: 144, Height: 100);
      LayoutMode: CenterMiddle;
      Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 8);

      Group #IconPreview {
        Anchor: (Width: 64, Height: 64);
        Background: (TexturePath: "Textures/BetterMarkerMap/MapMarkers/UserA.png");
      }

      Label #SelectedTag {
        Text: "SELECTED";
        Anchor: (Top: 4, Right: 4, Width: 66, Height: 16);
        Style: (...$C.@DefaultLabelStyle, FontSize: 10, TextColor: #63d471, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        Visible: false;
      }
    }

    Group { Anchor: (Width: 144, Height: 8); }

    Label #IconName {
      Text: "UserA.png";
      Anchor: (Width: 144, Height: 18);
      Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #f0e7da, HorizontalAlignment: Center, VerticalAlignment: Center);
    }

    Group { Anchor: (Width: 144, Height: 10); }

    $C.@TextButton #SelectButton {
      Text: "Select";
      Anchor: (Width: 120, Height: 32, Horizontal: 0);
    }
  }
}
