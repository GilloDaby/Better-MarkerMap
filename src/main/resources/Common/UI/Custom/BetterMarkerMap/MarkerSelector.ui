$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 980, Height: 720);

    #Title {
      $C.@Title #TitleText {
        Text: "Marker Icon Selector";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 20);

      Label #CurrentIconLabel {
        Text: "Current Global Icon";
        Anchor: (Height: 22, Horizontal: 8);
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #c8d7ea, RenderBold: true);
      }

      Label #CurrentIconValue {
        Text: "Vanilla (packet-selected)";
        Anchor: (Height: 20, Bottom: 8, Horizontal: 8);
        Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9fb3c9);
      }

      Group #CurrentPreviewRow {
        Anchor: (Height: 88, Bottom: 10, Horizontal: 8);
        LayoutMode: Left;
        Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 10);

        Group #CurrentIconPreview {
          Visible: false;
          Anchor: (Width: 64, Height: 64);
          Background: (TexturePath: "Textures/BetterMarkerMap/MapMarkers/UserA.png");
        }

        Group { Anchor: (Width: 14); }

        Label #CurrentPreviewHint {
          Text: "Current global marker icon preview";
          Anchor: (Height: 22, Horizontal: 8);
          Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #c8d7ea, RenderBold: true);
        }
      }

      Group #ScrollArea {
        Anchor: (Height: 402, Horizontal: 8);
        LayoutMode: TopScrolling;
        Padding: (Left: 18, Right: 18, Top: 12, Bottom: 12);
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 10);
        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        Group #MarkerList {
          Anchor: (Full: 0);
          LayoutMode: LeftCenterWrap;
        }
      }

      Label #EmptyLabel {
        Text: "";
        Anchor: (Bottom: 10, Horizontal: 8);
        Style: (...$C.@DefaultLabelStyle, HorizontalAlignment: Center, FontSize: 13, TextColor: #9fb3c9);
      }

      Group #Footer {
        LayoutMode: Center;
        Anchor: (Top: 10);

        $C.@TextButton #ReloadButton {
          @Anchor = (Width: 180, Height: 40);
          Text: "Reload Icons";
        }

        Group { Anchor: (Width: 14); }

        $C.@TextButton #UseVanillaButton {
          @Anchor = (Width: 180, Height: 40);
          Text: "Use Vanilla";
        }

        Group { Anchor: (Width: 14); }

        $C.@TextButton #CloseButton {
          @Anchor = (Width: 180, Height: 40);
          Text: "Close";
        }
      }
    }
  }
}

$C.@BackButton {}
